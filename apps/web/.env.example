# TON Connect manifest URL (required for TON AppKit)
NEXT_PUBLIC_TON_MANIFEST_URL=

# Reown Cloud project ID (required for the EVM wallet connection / AppKit)
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Telegram bot username (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ton_yx_bot
