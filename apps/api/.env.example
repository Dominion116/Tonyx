# Omniston SDK API key
OMNISTON_API_KEY=

# TonAPI key for wallet balance and transaction data
TONAPI_KEY=

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# MongoDB database name
MONGODB_DB_NAME=tonyx

# Telegram Bot API token (from BotFather)
TELEGRAM_BOT_TOKEN=

# HMAC secret for Telegram webhook verification
TELEGRAM_WEBHOOK_SECRET=

# Secret for protecting the cron scan endpoint
CRON_SECRET=

# JWT signing secret for session tokens
SESSION_SECRET=

# Port the API listens on
PORT=4000
